{
  "$schema": "https://biomejs.dev/schemas/2.5.0/schema.json",
  "files": {
    "includes": [
      "src/**",
      "!src/core/generated",
      "tests/**",
      "scripts/**",
      "examples/react-vite/src/**",
      "examples/react-vite/vite.config.ts",
      "tsup.config.ts",
      "playwright.config.ts",
      "package.json",
      "package-lock.json"
    ],
    "ignoreUnknown": true
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2
  },
  "linter": {
    "enabled": true,
    "rules": {
      "preset": "recommended"
    }
  }
}
