{
  "name": "vernier",
  "version": "0.0.0",
  "description": "A dev-time Vite overlay that measures UI problems and exports agent-readable sessions.",
  "type": "module",
  "private": true,
  "workspaces": [
    "examples/react-vite"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit && tsc --noEmit -p examples/react-vite/tsconfig.json",
    "test:e2e": "playwright test",
    "verify:m0": "npm run typecheck && npm run build && npm --prefix examples/react-vite run build"
  },
  "keywords": [
    "vite",
    "ui",
    "overlay",
    "codex"
  ],
  "license": "MIT",
  "peerDependencies": {
    "vite": "^7.0.0"
  },
  "dependencies": {
    "html2canvas": "^1.4.1"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "@playwright/test": "^1.56.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "playwright": "^1.56.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.9.0",
    "vite": "^7.0.0"
  }
}
