{
  "name": "vernier",
  "version": "0.0.0",
  "description": "A dev-time UI overlay that measures web app problems and exports agent-readable sessions.",
  "type": "module",
  "private": true,
  "workspaces": [
    "examples/react-vite"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "bin": {
    "vernier": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prebuild": "node scripts/build-overlay-bundle.mjs",
    "build": "tsup",
    "dev:example": "npm --prefix examples/react-vite run dev",
    "dev:proxy": "npm run build && node dist/cli.js",
    "proxy:5173": "node dist/cli.js --target http://localhost:5173 --port 3333",
    "proxy:3000": "node dist/cli.js --target http://localhost:3000 --port 3333",
    "typecheck": "tsc --noEmit && tsc --noEmit -p examples/react-vite/tsconfig.json",
    "test:unit": "node tests/session-writer.test.mjs && node tests/session-handler.test.mjs && node tests/overlay-options.test.mjs && node tests/args.test.mjs",
    "test:e2e": "playwright test",
    "test:proxy": "node tests/proxy-smoke.mjs",
    "verify:m0": "npm run typecheck && npm run build && npm run test:unit && npm --prefix examples/react-vite run build"
  },
  "keywords": [
    "vite",
    "ui",
    "overlay",
    "codex"
  ],
  "license": "MIT",
  "peerDependencies": {
    "vite": "^7.0.0"
  },
  "dependencies": {
    "html2canvas": "^1.4.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.0",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "esbuild": "^0.27.7",
    "playwright": "^1.56.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.9.0",
    "vite": "^7.0.0"
  }
}
